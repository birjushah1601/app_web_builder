# ─────────────────────────────────────────────────────────────────────────────
# Atlas Web — env reference
# Copy to .env.local and fill in values. Every Atlas feature flag defaults to
# OFF; flipping a flag here turns the corresponding plan's behavior on.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Auth (Clerk — default) ──────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# ─── Auth (Keycloak — sovereign deployments) ────────────────────────────────
# Flip to "1" to route /auth/* through Keycloak instead of Clerk.
# ATLAS_FF_AUTH_KEYCLOAK=1
# Required when the flag is on:
# ATLAS_SESSION_SECRET=replace_with_at_least_32_chars
# KEYCLOAK_BASE_URL=https://keycloak.example.com
# KEYCLOAK_REALM=atlas
# KEYCLOAK_CLIENT_ID=atlas-web
# KEYCLOAK_CLIENT_SECRET=replace_me

# ─── Database (A.1 docker-compose Postgres) ──────────────────────────────────
DATABASE_URL=postgres://atlas:atlas@localhost:5440/atlas_dev

# ─── LLM provider (D.1 — pick ONE; precedence: BASE_URL > ANTHROPIC_API_KEY) ──
# Local OpenAI-compat proxy (e.g. claude-max-api-proxy on :3456):
ATLAS_LLM_BASE_URL=http://127.0.0.1:3456
ATLAS_LLM_API_KEY=sk-no-auth
# Models the local proxy understands (Anthropic-rebadged names):
ATLAS_LLM_TRIAGE_MODEL=claude-haiku-4-5
ATLAS_LLM_DEEP_MODEL=claude-sonnet-4
# Developer model — defaults to deep_model. Override to claude-haiku-4-5
# if the local proxy times out at 5 min on sonnet-tier non-trivial diffs.
# ATLAS_LLM_DEVELOPER_MODEL=claude-haiku-4-5
# Plan I per-role model overrides (default to deep_model when unset):
# ATLAS_LLM_SECURITY_MODEL=claude-opus-4-7
# ATLAS_LLM_A11Y_MODEL=claude-sonnet-4
# Developer parallel mode — set to "true" for single-provider proxy setups
# (avoids hammering one endpoint with concurrent tool-use requests).
# ATLAS_DEVELOPER_SEQUENTIAL=true
# Verbose conductor logging — set to any truthy value to log every checkpoint.
# ATLAS_LOG_CHECKPOINTS=1

# Or: real Anthropic API (used only when ATLAS_LLM_BASE_URL is unset).
# ANTHROPIC_API_KEY=sk-ant-replace_me

# ─── E2B Sandbox (Plan E.4) ──────────────────────────────────────────────────
E2B_API_KEY=your_e2b_api_key_here
# Pin specific E2B template versions (updated weekly by template-rebuild workflow):
E2B_TEMPLATE_NEXT_TS_DIGEST=sha256:replace_with_real_digest
E2B_TEMPLATE_PYTHON_FASTAPI_DIGEST=sha256:replace_with_real_digest
# Optional Plan B-4 templates:
# E2B_TEMPLATE_REACT_VITE_DIGEST=sha256:...
# E2B_TEMPLATE_ASTRO_DIGEST=sha256:...
# E2B_TEMPLATE_SVELTEKIT_DIGEST=sha256:...
# E2B_TEMPLATE_EXPO_DIGEST=sha256:...
# Template name (or ID) of the E2B sandbox image used for live preview.
# Default: atlas-next-ts (Next.js 15 + Tailwind 3 + shadcn/ui + lucide-react).
# Republish via packages/sandbox-e2b/templates/atlas-next-ts/scripts/build-template.sh
ATLAS_DEFAULT_SANDBOX_TEMPLATE=atlas-next-ts
ATLAS_DEFAULT_SANDBOX_PORT=3000
# Spend tracking:
SANDBOX_HOURLY_RATE_USD=0.017
SANDBOX_SPEND_CAP_USD_PER_PROJECT_MONTH=50

# ─────────────────────────────────────────────────────────────────────────────
# Feature flags — ALL DEFAULT OFF. Flip to "true" to enable.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Plan E.0 / G / F: Live events (broker + SSE + persistent rail + preview reload) ─
# Single flag drives all three: SSE event broker on /api/projects/[id]/events,
# 360px persistent left-rail with ChatPanel + RitualTimeline, and HMR preview
# auto-reload on developer.diff.applied. Flag-OFF = today's one-shot UX.
# ATLAS_LIVE_EVENTS=true

# ─── Plan H: Persistent ritual snapshots ────────────────────────────────────
# When on, RitualEngine.getRitual() falls back to a Postgres-backed
# SpecEventsHydrator on in-memory miss — process restart no longer loses
# ritual history. Replays spec_events into a RitualSnapshot.
# ATLAS_RITUAL_HYDRATION=true

# ─── Plan I: Security + Accessibility roles (per-role flags) ────────────────
# After a successful developer dispatch with a real diff, dispatch
# SecurityRole (L4 gate) and/or AccessibilityRole (L5 gate). A failing gate
# escalates the ritual via ritual.escalation_requested.
# ATLAS_FF_SECURITY_ROLE=true
# ATLAS_FF_A11Y_ROLE=true

# ─── Plan J: Run-page Grafana wiring ────────────────────────────────────────
# Flag + both env vars below required. Without all three, Run page renders
# the "unknown" placeholder (today's behavior) — no crash on missing config.
# ATLAS_FF_RUN_GRAFANA=true
# ATLAS_GRAFANA_URL=https://grafana.atlas.app/api/datasources/proxy/1
# ATLAS_GRAFANA_TOKEN=glsa_replace_me
# Tempo deeplink base for the Priya-persona trace explorer:
# GRAFANA_TRACE_URL_BASE=https://grafana.atlas.app/explore?orgId=1&traceId=

# ─── Plan K: Multi-turn ritual refinement ───────────────────────────────────
# When on, ChatPanel renders a "Refine" textarea under each developer-output
# card. Refining starts a NEW ritual linked to the parent via parentRitualId;
# architect prompt prepends a "Previous turn" preamble.
# ATLAS_FF_MULTI_TURN=true

# ─── Plan L: Developer fix-loop on gate failure ─────────────────────────────
# When ATLAS_FF_AUTO_FIX_LOOP=true AND a Plan I gate (security or a11y)
# fails, the engine auto-triggers an internal _runRitual() with the gate
# report folded into PriorRitualContext as "## Gate findings". The architect
# sees the original plan + diff + gate failures and produces an updated plan;
# the developer regenerates a diff; the gates re-run. Capped at 2 attempts
# per ritual lineage. Flag-OFF = today's escalate-and-stop behavior.
# Note: the loop fires inside the engine and does NOT call the public refine()
# Server Action — so ATLAS_FF_MULTI_TURN is NOT a prerequisite. (The user-
# facing refinement flow is separate from auto-fix.)
# ATLAS_FF_AUTO_FIX_LOOP=true

# ─── Plan S.2 — Researcher role + reference catalog ──────────────────────────
# Enables the Researcher role (catalog-only or +web). Default OFF.
ATLAS_FF_RESEARCHER=false

# When true AND BRAVE_SEARCH_API_KEY is set, Researcher attaches BraveSearchAdapter
# and live-fetches category references in addition to the local catalog.
ATLAS_RESEARCH_WEB=false

# Brave Search API key (https://api.search.brave.com — free tier covers ~2k queries/month).
# Only consulted when ATLAS_RESEARCH_WEB=true.
BRAVE_SEARCH_API_KEY=

# ─── Plan S.3 — Designer role + A2UI primitive ───────────────────────────────
# Enables the Designer role (architect/researcher artifact → DesignProposal).
# Inert until Plan S.4 wires the proposal into the canvas. Default OFF.
ATLAS_FF_DESIGNER=false

# ─── Plan S.4 — Canvas v1 (polymorphic shell + per-mode renderers) ──────────
# Replaces the projects/[id]/canvas right-pane preview-only canvas with the
# polymorphic <CanvasShell> (mode toggle + persona filter + register-renderers
# wiring up Designer / Refine / Preview canvases). Flag-OFF preserves today's
# Plan R preview-only tree byte-for-byte.
ATLAS_FF_CANVAS_V1=false

# ─── Plan S.5 — Visual-Quality merge gate ────────────
ATLAS_FF_VISUAL_QUALITY_GATE=false
ATLAS_VQ_GATE_MODEL=

# ─── Plan T.1 — Multi-stack templates ────────────────────────────────────────
# When true, architect's canvasManifest.artifactKind decides which E2B template
# the sandbox factory provisions. v1 ships atlas-fastapi for backend-rest-api;
# everything else still falls back to atlas-next-ts-v2.
# Per-project override via ATLAS_DEFAULT_SANDBOX_TEMPLATE (always wins).
# Default OFF.
ATLAS_FF_MULTI_STACK=false

# ─── ADR-001 OSS-stack pivot — stub flags (planned, not yet wired live) ─────
# These exist in lib/feature-flags.ts but their consumer code is partially
# stubbed. Flip to enable feature affordances; full backend lands per plan.
# ATLAS_FF_FIGMA_IMPORTER=true   # B-5 (needs Figma API token + design files)
# ATLAS_FF_STRIPE_PAYMENTS=true  # C-5 (idempotency + webhook signatures)
# ATLAS_FF_VIDEO_KLING=true      # B-6 (needs KLING_API_KEY + atlas-web wiring)
# KLING_API_KEY=replace_me

# ─────────────────────────────────────────────────────────────────────────────
# E2E test secrets (only needed when running pnpm test:e2e — not for dev)
# ─────────────────────────────────────────────────────────────────────────────
# ATLAS_TEST_PASSWORD=replace_me
# DATABASE_URL_TEST=postgres://atlas:atlas@localhost:5440/atlas_test
