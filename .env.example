# ─────────────────────────────────────────────────────────────────────────────
# Atlas — workspace-root env (Postgres bootstrap, root tooling).
# For atlas-web app config (LLM provider, sandbox, feature flags, etc.) see
# apps/atlas-web/.env.example.
# ─────────────────────────────────────────────────────────────────────────────

# Spec Graph data layer
# Atlas Postgres listens on host port 5440 (see docker-compose.yml).
DATABASE_URL=postgresql://atlas:atlas@localhost:5440/atlas_dev
DATABASE_URL_TEST=postgresql://atlas:atlas@localhost:5440/atlas_test

# Clerk (Atlas Web — also documented in apps/atlas-web/.env.example)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me

# ─────────────────────────────────────────────────────────────────────────────
# Atlas Web feature flags — see apps/atlas-web/.env.example for the full
# list. Quick reference of what's flippable:
#
#   ATLAS_LIVE_EVENTS         (Plan E.0/G/F — broker + rail + preview reload)
#   ATLAS_RITUAL_HYDRATION    (Plan H — persistent ritual snapshots)
#   ATLAS_FF_SECURITY_ROLE    (Plan I — L4 security gate after developer)
#   ATLAS_FF_A11Y_ROLE        (Plan I — L5 accessibility gate after developer)
#   ATLAS_FF_RUN_GRAFANA      (Plan J — Run page → real Grafana)
#   ATLAS_FF_MULTI_TURN       (Plan K — refinement loop in ChatPanel)
#   ATLAS_FF_AUTO_FIX_LOOP    (Plan L — auto-fix on gate failure)
#   ATLAS_FF_AUTH_KEYCLOAK    (D12 — sovereign self-host auth)
#   ATLAS_FF_FIGMA_IMPORTER   (B-5 — needs Figma token)
#   ATLAS_FF_STRIPE_PAYMENTS  (C-5)
#   ATLAS_FF_VIDEO_KLING      (B-6 — needs KLING_API_KEY)
#
# All default OFF.
# ─────────────────────────────────────────────────────────────────────────────
