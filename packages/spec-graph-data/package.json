{
  "name": "@atlas/spec-graph-data",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "drizzle"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@opentelemetry/api": "1.9.0",
    "drizzle-orm": "0.45.2",
    "pg": "8.13.1",
    "prom-client": "15.1.3"
  },
  "devDependencies": {
    "@types/node": "22.9.0",
    "@types/pg": "8.11.10",
    "drizzle-kit": "0.31.10",
    "typescript": "5.6.3",
    "vitest": "2.1.8"
  }
}
