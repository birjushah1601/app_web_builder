{
  "name": "atlas-bun-cli-sandbox",
  "version": "0.1.0",
  "description": "Bun + Commander + ink E2B sandbox template for Atlas (cli-tool artifactKind)",
  "type": "module",
  "private": true,
  "module": "src/cli.ts",
  "bin": {
    "atlas": "src/cli.ts"
  },
  "scripts": {
    "cli": "bun run src/cli.ts",
    "server": "bun run src/server.ts",
    "dev": "bun --hot src/server.ts",
    "test": "bun test",
    "build": "bun build --compile --target=bun-linux-x64 src/cli.ts --outfile dist/atlas"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "ink": "^5.0.1",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "ink-select-input": "^6.0.0",
    "chalk": "^5.3.0",
    "react": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "@types/react": "^18.3.12",
    "typescript": "^5.6.3"
  }
}
